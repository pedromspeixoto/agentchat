# Anthropic Configuration
# Option A – Direct Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Option B – Azure AI Foundry (comment out Option A and uncomment below)
# CLAUDE_CODE_USE_FOUNDRY=1
# ANTHROPIC_FOUNDRY_BASE_URL=https://<resource>.services.ai.azure.com/anthropic
# ANTHROPIC_FOUNDRY_API_KEY=<your-azure-api-key>
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
# ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6

# Workspace directory (defaults to /workspace in container, use "." for local)
AGENT_WORKSPACE=.
