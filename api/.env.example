# Environment: local, dev, prod
ENVIRONMENT=local
LOG_LEVEL=INFO

# Server
PORT=8080
HOST=0.0.0.0

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentchat
POSTGRES_USER=agentchat
POSTGRES_PASSWORD=agentchat

# Sandbox backend: "subprocess" (default, local) or "modal" (Modal.com cloud)
SANDBOX_BACKEND=subprocess

# Modal (required when SANDBOX_BACKEND=modal)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Anthropic Configuration (passed to agents in sandboxes)
# Option A – Direct Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Option B – Azure AI Foundry (comment out Option A and uncomment below)
# CLAUDE_CODE_USE_FOUNDRY=1
# ANTHROPIC_FOUNDRY_BASE_URL=https://<resource>.services.ai.azure.com/anthropic
# ANTHROPIC_FOUNDRY_API_KEY=<your-azure-api-key>
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
# ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6

# TAVILY API key (passed to agents in sandboxes)
TAVILY_API_KEY=sk-tavily-your-key-here